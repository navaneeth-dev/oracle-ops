import "package://pkg.pkl-lang.org/pkl-k8s/k8s@1.0.1#/K8sResource.pkl"
import "package://pkg.pkl-lang.org/pkl-k8s/k8s@1.0.1#/api/apps/v1/Deployment.pkl"

resources: Listing<K8sResource> = new {
  new Deployment {
    metadata {
      name = "backstage"
      labels {
        ["app"] = "backstage"
      }
    }
    spec {
      replicas = 1
      selector {
        matchLabels {
          ["app"] = "backstage"
        }
      }
      template {
        metadata {
          name = "backstage"
          labels {
            ["app"] = "backstage"
          }
        }
        spec {
          containers {
            new {
              name = "backstage"
              image = "ghcr.io/navaneeth-dev/backstage:v0.0.1"
              imagePullPolicy = "IfNotPresent"
              ports {
                new {
                  containerPort = 7007
                  protocol = "TCP"
                }
              }
            }
          }
          restartPolicy = "Always"
        }
      }
    }
  }
}

output {
  value = resources
  renderer = (K8sResource.output.renderer as YamlRenderer) {
    isStream = true
  }
}